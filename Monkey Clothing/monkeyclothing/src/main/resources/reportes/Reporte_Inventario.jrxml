<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
    "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="Reporte_Inventario" language="java"
    pageWidth="595" pageHeight="842"
    columnWidth="555" leftMargin="20" rightMargin="20"
    topMargin="20" bottomMargin="20">
    <queryString language="SQL">
        <![CDATA[
        SELECT
            p.codigo,
            p.descripcion,
            p.stock,
            p.precio_venta,
            c.descripcion AS categoria
        FROM producto p
        INNER JOIN categorias c ON p.idcate = c.idcate
        ]]>
    </queryString>
    <field name="codigo" class="java.lang.String"/>
    <field name="descripcion" class="java.lang.String"/>
    <field name="stock" class="java.lang.Integer"/>
    <field name="precio_venta" class="java.math.BigDecimal"/>
    <field name="categoria" class="java.lang.String"/>
    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="400" height="30"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Reporte de Inventario - Monkey Clothing]]></text>
            </staticText>
        </band>
    </title>
    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Código]]></text>
            </staticText>
            <staticText>
                <reportElement x="80" y="0" width="160" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Descripción]]></text>
            </staticText>
            <staticText>
                <reportElement x="240" y="0" width="70" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Stock]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="0" width="100" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Precio Venta]]></text>
            </staticText>
            <staticText>
                <reportElement x="410" y="0" width="145" height="20"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Categoría]]></text>
            </staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="80" height="17"/>
                <textFieldExpression><![CDATA[$F{codigo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="160" height="17"/>
                <textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="240" y="0" width="70" height="17"/>
                <textFieldExpression><![CDATA[$F{stock}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="310" y="0" width="100" height="17"/>
                <textFieldExpression><![CDATA[$F{precio_venta}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="410" y="0" width="145" height="17"/>
                <textFieldExpression><![CDATA[$F{categoria}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>