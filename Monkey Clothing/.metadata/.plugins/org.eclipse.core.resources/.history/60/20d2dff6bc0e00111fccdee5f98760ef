<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Monkey Clothing - Ventas</title>
    <link rel="stylesheet"
          href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
</head>
<body>
<nav class="navbar navbar-expand-md bg-dark navbar-dark">
    <a class="navbar-brand" href="#">Monkey Clothing</a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav">
            <li class="nav-item"><a class="nav-link" th:href="@{/usuario}">Usuarios</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/cliente}">Clientes</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/producto}">Productos</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/venta}">Ventas</a></li>
        </ul>
    </div>
</nav>

<div class="container mt-4">
    <h1>Lista de Ventas</h1>
    <a th:href="@{/venta/new}" class="btn btn-primary btn-sm mb-3">Nueva Venta</a>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nro Venta</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Asesor</th>
                <th>Subtotal</th>
                <th>IGV</th>
                <th>Total</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <tr th:each="item : ${ventas}">
                <td th:text="${item.id}"></td>
                <td th:text="${item.fecha}"></td>
                <td th:text="${item.cliente.razonSocial}"></td>
                <td th:text="${item.asesorVenta.nombres}"></td>
                <td th:text="${item.subtotal}"></td>
                <td th:text="${item.igv}"></td>
                <td th:text="${item.total}"></td>
                <td>
                    <a th:href="@{/venta/verDetalle/{id}(id=${item.id})}"
                       class="btn btn-primary btn-sm">Ver Detalle</a>
                </td>
            </tr>
        </tbody>
    </table>
</div>
</body>
</html>