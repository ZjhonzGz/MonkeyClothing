<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing — Productos</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #111;
        }

        .page-wrapper {
            max-width: 1100px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        /* Cabecera */
        .page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.8rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-header h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            letter-spacing: .08em;
            color: #111;
            line-height: 1;
        }

        .page-header p {
            font-size: .72rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .3rem;
        }

        .header-actions {
            display: flex;
            gap: .8rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn-mc {
            border: none;
            padding: .65rem 1.4rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: .85rem;
            letter-spacing: .2em;
            text-decoration: none !important;
            transition: background .2s;
            white-space: nowrap;
            display: inline-block;
        }

        .btn-mc-dark {
            background: #111;
            color: #f2f0eb !important;
        }

        .btn-mc-dark:hover { background: #ff3b00; color: #fff !important; }

        .btn-mc-outline {
            background: transparent;
            color: #111 !important;
            border: 1px solid #111;
        }

        .btn-mc-outline:hover {
            background: #111;
            color: #f2f0eb !important;
        }

        /* Tabla */
        .table-wrap {
            background: #fff;
            border-top: 3px solid #ff3b00;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr { border-bottom: 1px solid #eee; }

        thead th {
            font-size: .6rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: #aaa;
            padding: 1rem 1.2rem;
            font-weight: 400;
            text-align: left;
        }

        tbody tr {
            border-bottom: 1px solid #f4f4f4;
            transition: background .15s;
        }

        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #fafafa; }

        tbody td {
            padding: .9rem 1.2rem;
            font-size: .88rem;
            color: #333;
        }

        /* Badge categoría */
        .badge-cat {
            display: inline-block;
            font-size: .58rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            background: #f2f0eb;
            color: #555;
            padding: .25rem .7rem;
            border: 1px solid #ddd;
        }

        /* Badge stock */
        .stock-ok  { color: #111; font-weight: 500; }
        .stock-low { color: #ff3b00; font-weight: 500; }

        /* Precio */
        .precio { font-weight: 500; }

        /* Acciones */
        .btn-accion {
            font-size: .6rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            text-decoration: none !important;
            padding: .3rem .75rem;
            border: 1px solid;
            transition: background .2s, color .2s;
            display: inline-block;
        }

        .btn-editar { color: #111 !important; border-color: #111; }
        .btn-editar:hover { background: #111; color: #f2f0eb !important; }

        .btn-eliminar { color: #ff3b00 !important; border-color: #ff3b00; margin-left: .4rem; }
        .btn-eliminar:hover { background: #ff3b00; color: #fff !important; }

        .empty {
            text-align: center;
            padding: 3rem;
            font-size: .8rem;
            color: #bbb;
            letter-spacing: .1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

<nav th:replace="~{componentes/navbar :: navbar}"></nav>

<div class="page-wrapper">

    <div class="page-header">
        <div>
            <h1>Productos</h1>
            <p>Gestión de inventario</p>
        </div>
        <div class="header-actions">
            <a th:href="@{/reportes/inventario/pdf}" target="_blank" class="btn-mc btn-mc-outline">
                📄 Reporte PDF
            </a>
            <a th:href="@{/productos/nuevo}" class="btn-mc btn-mc-dark">+ Nuevo Producto</a>
        </div>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Código</th>
                    <th>Descripción</th>
                    <th>Precio Venta</th>
                    <th>Stock</th>
                    <th>Categoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr th:if="${#lists.isEmpty(productos)}">
                    <td colspan="7" class="empty">No hay productos registrados</td>
                </tr>
                <tr th:each="p : ${productos}">
                    <td th:text="${p.idproducto}"></td>
                    <td th:text="${p.codigo}"></td>
                    <td th:text="${p.descripcion}"></td>
                    <td class="precio" th:text="'S/ ' + ${p.precioVenta}"></td>
                    <td>
                        <span th:text="${p.stock}"
                              th:class="${p.stock <= 5} ? 'stock-low' : 'stock-ok'"></span>
                    </td>
                    <td><span class="badge-cat" th:text="${p.categoria.descripcion}"></span></td>
                    <td>
                        <a th:href="@{/productos/editar/{id}(id=${p.idproducto})}"
                           class="btn-accion btn-editar">Editar</a>
                        <a th:href="@{/productos/eliminar/{id}(id=${p.idproducto})}"
                           class="btn-accion btn-eliminar"
                           onclick="return confirm('¿Eliminar producto?')">Eliminar</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
</body>
</html>