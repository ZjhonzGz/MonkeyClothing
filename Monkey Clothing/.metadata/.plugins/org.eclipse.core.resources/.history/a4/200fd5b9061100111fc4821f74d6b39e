package com.cibertec.monkey.service.impl;

import java.math.BigDecimal;
import java.util.List;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import com.cibertec.monkey.dto.ProductoStockDTO;
import com.cibertec.monkey.dto.VentaResumenDTO;
import com.cibertec.monkey.repository.DashboardRepository;
import com.cibertec.monkey.service.DashboardService;

@Service
public class DashboardServiceImpl implements DashboardService {

    @Autowired
    private DashboardRepository repo;

    @Override
    public Long contarVentasHoy() {
        return repo.contarVentasHoy();
    }

    @Override
    public BigDecimal totalIngresosMes() {
        return repo.totalIngresosMes();
    }

    @Override
    public BigDecimal totalGananciaMes() {
        return repo.totalGananciaMes();
    }

    @Override
    public Long contarProductosStockBajo(int umbral) {
        return repo.contarProductosStockBajo(umbral);
    }

    @Override
    public List<ProductoStockDTO> listarProductosStockBajo(int umbral) {
        return repo.listarProductosStockBajo(umbral);
    }

    @Override
    public List<VentaResumenDTO> ultimasVentas(int limite) {
        return repo.ultimasVentas(limite);
    }
}