<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #fff;
            width: 100%;
            max-width: 400px;
            padding: 3rem 2.5rem;
            border-top: 4px solid #ff3b00;
        }

        /* Logo */
        .brand {
            text-align: center;
            margin-bottom: 2.2rem;
        }

        .brand-name {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: .15em;
            color: #111;
            display: block;
        }

        .brand-sub {
            font-size: .65rem;
            letter-spacing: .3em;
            text-transform: uppercase;
            color: #aaa;
        }

        /* Title */
        .form-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.6rem;
            letter-spacing: .08em;
            color: #111;
            margin-bottom: .3rem;
        }

        .form-sub {
            font-size: .78rem;
            color: #aaa;
            margin-bottom: 1.5rem;
        }

        .divider {
            width: 100%;
            height: 1px;
            background: #eee;
            margin-bottom: 1.8rem;
        }

        /* Error */
        .alert {
            font-size: .78rem;
            color: #ff3b00;
            background: rgba(255,59,0,.06);
            border-left: 3px solid #ff3b00;
            padding: .65rem 1rem;
            margin-bottom: 1.5rem;
        }

        /* Campos */
        .field { margin-bottom: 1.5rem; }

        .field label {
            display: block;
            font-size: .62rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #999;
            margin-bottom: .5rem;
        }

        .field input {
            width: 100%;
            border: none;
            border-bottom: 1.5px solid #ddd;
            padding: .6rem 0;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            color: #111;
            background: transparent;
            outline: none;
            transition: border-color .2s;
        }

        .field input:focus { border-color: #111; }

        /* Botón */
        .btn {
            width: 100%;
            background: #111;
            color: #f2f0eb;
            border: none;
            padding: .95rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: .95rem;
            letter-spacing: .3em;
            cursor: pointer;
            margin-top: .5rem;
            transition: background .2s;
        }

        .btn:hover { background: #ff3b00; }

        /* Link */
        .footer-link {
            margin-top: 1.5rem;
            text-align: center;
            font-size: .75rem;
            color: #aaa;
        }

        .footer-link a {
            color: #111;
            font-weight: 500;
            text-decoration: none;
            border-bottom: 1px solid #111;
        }

        .footer-link a:hover { color: #ff3b00; border-color: #ff3b00; }
    </style>
</head>
<body>

<div class="card">

    <div class="brand">
        <span class="brand-name">Monkey Clothing</span>
        <span class="brand-sub">Panel Administrativo</span>
    </div>

    <h2 class="form-title">INICIAR SESIÓN</h2>
    <p class="form-sub">Ingresa tus credenciales para continuar</p>

    <div class="divider"></div>

    <div class="alert" th:if="${error}" th:text="${error}"></div>

    <form th:action="@{/login}" method="post">

        <div class="field">
            <label for="usuario">Usuario</label>
            <input type="text" id="usuario" name="usuario" required/>
        </div>

		<div class="field">
		            <label for="clave">Contraseña</label>
		            <div class="pw-wrap">
		                <input type="password" id="clave" name="clave" required/>
		                <button type="button" class="pw-eye" onclick="togglePw()" title="Mostrar contraseña">
		                    <!-- Ojo abierto -->
		                    <svg id="icon-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
		                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
		                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
		                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
		                        <circle cx="12" cy="12" r="3"/>
		                    </svg>
		                    <!-- Ojo tachado (oculto por defecto) -->
		                    <svg id="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
		                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
		                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
		                         style="display:none">
		                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8
		                                 a18.45 18.45 0 0 1 5.06-5.94"/>
		                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8
		                                 a18.5 18.5 0 0 1-2.16 3.19"/>
		                        <line x1="1" y1="1" x2="23" y2="23"/>
		                    </svg>
		                </button>
		            </div>
		        </div>

        <button type="submit" class="btn">Ingresar →</button>

    </form>
</div>

</body>
</html>