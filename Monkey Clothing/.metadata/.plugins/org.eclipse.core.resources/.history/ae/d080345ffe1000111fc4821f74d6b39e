<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing — Usuarios</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #111;
        }

        .page-wrapper {
            max-width: 1000px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        /* Cabecera */
        .page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.8rem;
        }

        .page-header h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            letter-spacing: .08em;
            color: #111;
            line-height: 1;
        }

        .page-header p {
            font-size: .72rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .3rem;
        }

        .btn-nuevo {
            background: #111;
            color: #f2f0eb;
            border: none;
            padding: .65rem 1.4rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: .85rem;
            letter-spacing: .2em;
            text-decoration: none;
            transition: background .2s;
            white-space: nowrap;
        }

        .btn-nuevo:hover {
            background: #ff3b00;
            color: #fff;
            text-decoration: none;
        }

        /* Tabla */
        .table-wrap {
            background: #fff;
            border-top: 3px solid #ff3b00;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            border-bottom: 1px solid #eee;
        }

        thead th {
            font-size: .6rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: #aaa;
            padding: 1rem 1.2rem;
            font-weight: 400;
            text-align: left;
        }

        tbody tr {
            border-bottom: 1px solid #f4f4f4;
            transition: background .15s;
        }

        tbody tr:last-child { border-bottom: none; }

        tbody tr:hover { background: #fafafa; }

        tbody td {
            padding: .9rem 1.2rem;
            font-size: .88rem;
            color: #333;
        }

        /* Badge rol */
        .badge-rol {
            display: inline-block;
            font-size: .58rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            background: #111;
            color: #f2f0eb;
            padding: .25rem .7rem;
        }

        /* Acciones */
        .btn-accion {
            font-size: .6rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            text-decoration: none;
            padding: .3rem .75rem;
            border: 1px solid;
            transition: background .2s, color .2s;
            display: inline-block;
        }

        .btn-editar {
            color: #111;
            border-color: #111;
        }

        .btn-editar:hover {
            background: #111;
            color: #f2f0eb;
            text-decoration: none;
        }

        .btn-eliminar {
            color: #ff3b00;
            border-color: #ff3b00;
            margin-left: .4rem;
        }

        .btn-eliminar:hover {
            background: #ff3b00;
            color: #fff;
            text-decoration: none;
        }

        /* Sin datos */
        .empty {
            text-align: center;
            padding: 3rem;
            font-size: .8rem;
            color: #bbb;
            letter-spacing: .1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

<nav th:replace="~{componentes/navbar :: navbar}"></nav>

<div class="page-wrapper">

    <!-- Cabecera -->
    <div class="page-header">
        <div>
            <h1>Usuarios</h1>
            <p>Gestión de accesos al panel</p>
        </div>
        <a href="/usuario/new" class="btn-nuevo">+ Nuevo Usuario</a>
    </div>

    <!-- Tabla -->
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr th:if="${#lists.isEmpty(usuarios)}">
                    <td colspan="6" class="empty">No hay usuarios registrados</td>
                </tr>
                <tr th:each="u : ${usuarios}">
                    <td th:text="${u.id}"></td>
                    <td th:text="${u.nombres}"></td>
                    <td th:text="${u.apellidos}"></td>
                    <td th:text="${u.usuario}"></td>
                    <td><span class="badge-rol" th:text="${u.rol.descripcion}"></span></td>
                    <td>
                        <a th:href="@{/usuario/edit/{id}(id=${u.id})}" class="btn-accion btn-editar">Editar</a>
                        <a th:href="@{/usuario/delete/{id}(id=${u.id})}" class="btn-accion btn-eliminar"
                           onclick="return confirm('¿Eliminar este usuario?')">Eliminar</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

</body>
</html>