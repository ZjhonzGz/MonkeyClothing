<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing — Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #111;
        }

        .page-wrapper {
            max-width: 1100px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        /* ── HEADER ── */
        .dash-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .dash-header h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.4rem;
            letter-spacing: .08em;
            line-height: 1;
        }

        .dash-header p {
            font-size: .7rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .3rem;
        }

        /* Reloj */
        .clock-block {
            text-align: right;
        }

        .clock-time {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: .1em;
            color: #111;
            line-height: 1;
        }

        .clock-date {
            font-size: .68rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .2rem;
        }

        /* ── MÉTRICAS ── */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 1.8rem;
        }

        .metric-card {
            background: #fff;
            border-top: 3px solid #111;
            padding: 1.4rem 1.2rem;
        }

        .metric-card.accent { border-top-color: #ff3b00; }

        .metric-label {
            font-size: .58rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #aaa;
            margin-bottom: .6rem;
        }

        .metric-value {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: .05em;
            color: #111;
            line-height: 1;
        }

        .metric-value.orange { color: #ff3b00; }

        .metric-sub {
            font-size: .68rem;
            color: #bbb;
            margin-top: .4rem;
            letter-spacing: .05em;
        }

        /* ── GRID PRINCIPAL ── */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 1rem;
        }

        /* ── TABLA ── */
        .panel {
            background: #fff;
            border-top: 3px solid #ff3b00;
        }

        .panel.dark { border-top-color: #111; }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.2rem;
            border-bottom: 1px solid #f0ede8;
        }

        .panel-title {
            font-size: .6rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: #aaa;
        }

        .panel-link {
            font-size: .58rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            color: #ff3b00;
            text-decoration: none;
        }

        .panel-link:hover { text-decoration: underline; }

        table { width: 100%; border-collapse: collapse; }

        thead th {
            font-size: .58rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #bbb;
            padding: .8rem 1.2rem;
            text-align: left;
            font-weight: 400;
        }

        tbody tr { border-top: 1px solid #f4f4f4; transition: background .15s; }
        tbody tr:hover { background: #fafafa; }

        tbody td {
            padding: .75rem 1.2rem;
            font-size: .85rem;
            color: #333;
        }

        /* ── STOCK BAJO ── */
        .stock-list { padding: .5rem 0; }

        .stock-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .85rem 1.2rem;
            border-top: 1px solid #f4f4f4;
        }

        .stock-item:first-child { border-top: none; }

        .stock-info { flex: 1; }

        .stock-name {
            font-size: .85rem;
            color: #111;
            margin-bottom: .2rem;
        }

        .stock-cat {
            font-size: .65rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #bbb;
        }

        .stock-badge {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.1rem;
            letter-spacing: .05em;
            min-width: 48px;
            text-align: right;
        }

        .stock-badge.critical { color: #ff3b00; }
        .stock-badge.warning  { color: #e67e00; }

        .stock-bar-wrap {
            width: 60px;
            height: 3px;
            background: #f0ede8;
            margin-left: 1rem;
            flex-shrink: 0;
        }

        .stock-bar {
            height: 3px;
            background: #ff3b00;
            transition: width .3s;
        }

        .stock-bar.warning { background: #e67e00; }

        /* Sin datos */
        .empty {
            text-align: center;
            padding: 2.5rem;
            font-size: .75rem;
            color: #ccc;
            letter-spacing: .1em;
            text-transform: uppercase;
        }

        /* ── ALERT BANNER ── */
        .alert-banner {
            display: flex;
            align-items: center;
            gap: .8rem;
            background: #fff3ee;
            border-left: 3px solid #ff3b00;
            padding: .8rem 1.2rem;
            margin-bottom: 1rem;
            font-size: .8rem;
            color: #c0392b;
        }

        .alert-banner span { font-weight: 500; }

        /* Responsive */
        @media (max-width: 768px) {
            .metrics-grid { grid-template-columns: repeat(2, 1fr); }
            .main-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<nav th:replace="~{componentes/navbar :: navbar}"></nav>

<div class="page-wrapper">

    <!-- ── HEADER + RELOJ ── -->
    <div class="dash-header">
        <div>
            <h1>Dashboard</h1>
            <p>Resumen operativo — Monkey Clothing</p>
        </div>
        <div class="clock-block">
            <div class="clock-time" id="clock">00:00:00</div>
            <div class="clock-date" id="clock-date">—</div>
        </div>
    </div>

    <!-- ── BANNER ALERTA STOCK ── -->
    <div class="alert-banner" th:if="${stockBajoCount > 0}">
        ⚠ <span th:text="${stockBajoCount}">0</span>
        producto(s) con stock crítico (≤ 20 unidades). Revisa la sección de inventario.
    </div>

    <!-- ── MÉTRICAS ── -->
    <div class="metrics-grid">

        <div class="metric-card accent">
            <div class="metric-label">Ventas hoy</div>
            <div class="metric-value orange"
                 th:text="${ventasHoy != null} ? ${ventasHoy} : '0'">0</div>
            <div class="metric-sub">Transacciones del día</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Ingresos del mes</div>
            <div class="metric-value"
                 th:text="${ingresosMes != null} ? 'S/ ' + ${#numbers.formatDecimal(ingresosMes, 1, 2)} : 'S/ 0.00'">S/ 0.00</div>
            <div class="metric-sub">Total facturado</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Ganancia del mes</div>
            <div class="metric-value"
                 th:text="${gananciaMes != null} ? 'S/ ' + ${#numbers.formatDecimal(gananciaMes, 1, 2)} : 'S/ 0.00'">S/ 0.00</div>
            <div class="metric-sub">Margen neto</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Productos con stock bajo</div>
            <div class="metric-value"
                 th:classappend="${stockBajoCount > 0} ? 'orange' : ''"
                 th:text="${stockBajoCount != null} ? ${stockBajoCount} : '0'">0</div>
            <div class="metric-sub">Umbral: ≤ 20 unidades</div>
        </div>

    </div>

    <!-- ── GRID PRINCIPAL ── -->
    <div class="main-grid">

        <!-- Últimas ventas -->
        <div class="panel">
            <div class="panel-head">
                <span class="panel-title">Últimas ventas</span>
                <a href="/venta" class="panel-link">Ver todas →</a>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Asesor</th>
                        <th>Total</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    <tr th:if="${#lists.isEmpty(ultimasVentas)}">
                        <td colspan="5" class="empty">Sin ventas registradas</td>
                    </tr>
                    <tr th:each="v : ${ultimasVentas}">
                        <td th:text="${v.nroventa}"></td>
                        <td th:text="${v.cliente}"></td>
                        <td th:text="${v.asesor}"></td>
                        <td th:text="'S/ ' + ${#numbers.formatDecimal(v.total, 1, 2)}"></td>
                        <td th:text="${#temporals.format(v.fecha, 'dd/MM/yyyy')}"></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Stock bajo -->
        <div class="panel dark">
            <div class="panel-head">
                <span class="panel-title">Stock crítico</span>
                <a href="/productos" class="panel-link">Ver inventario →</a>
            </div>
            <div class="stock-list">
                <div th:if="${#lists.isEmpty(productosStockBajo)}" class="empty">
                    Todo el inventario está bien ✓
                </div>
                <div class="stock-item" th:each="p : ${productosStockBajo}">
                    <div class="stock-info">
                        <div class="stock-name" th:text="${p.descripcion}">Producto</div>
                        <div class="stock-cat" th:text="${p.categoria}">Categoría</div>
                    </div>
                    <div class="stock-badge"
                         th:classappend="${p.stock <= 10} ? 'critical' : 'warning'"
                         th:text="${p.stock}">0</div>
                    <div class="stock-bar-wrap">
                        <div class="stock-bar"
                             th:classappend="${p.stock <= 10} ? '' : 'warning'"
                             th:style="'width:' + ${p.stock * 5} + '%'"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>

<script>
    // Reloj en tiempo real
    const DIAS   = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
    const MESES  = ['Enero','Febrero','Marzo','Abril','Mayo','Junio',
                    'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

    function updateClock() {
        const now  = new Date();
        const h    = String(now.getHours()).padStart(2,'0');
        const m    = String(now.getMinutes()).padStart(2,'0');
        const s    = String(now.getSeconds()).padStart(2,'0');
        document.getElementById('clock').textContent = `${h}:${m}:${s}`;
        document.getElementById('clock-date').textContent =
            `${DIAS[now.getDay()]}, ${now.getDate()} de ${MESES[now.getMonth()]} ${now.getFullYear()}`;
    }

    updateClock();
    setInterval(updateClock, 1000);
</script>

</body>
</html>