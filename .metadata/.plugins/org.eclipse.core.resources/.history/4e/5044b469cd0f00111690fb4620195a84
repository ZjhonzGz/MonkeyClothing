<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Monkey Clothing - Editar Cliente</title>
</head>
<body>

<h1>Editar Cliente</h1>

<form th:action="@{/cliente/update/{id}(id=${cliente.id})}"
      th:object="${cliente}" method="post">
    <div>
        <label>Razón Social:</label>
        <input type="text" th:field="*{razonSocial}" placeholder="Razón social"/>
    </div>
    <div>
        <label>Ciudad:</label>
        <input type="text" th:field="*{ciudad}" placeholder="Ciudad"/>
    </div>
    <div>
        <label>Dirección:</label>
        <input type="text" th:field="*{direccion}" placeholder="Dirección"/>
    </div>
    <div>
        <label>Teléfono:</label>
        <input type="text" th:field="*{telefono}" placeholder="Teléfono"/>
    </div>
    <button type="submit">Actualizar</button>
    <a href="/cliente">Cancelar</a>
</form>

</body>
</html>