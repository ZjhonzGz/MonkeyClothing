<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing — Nueva Venta</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #111;
        }

        .page-wrapper {
            max-width: 1100px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        .page-header { margin-bottom: 1.8rem; }

        .page-header h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            letter-spacing: .08em;
            color: #111;
            line-height: 1;
        }

        .page-header p {
            font-size: .72rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .3rem;
        }

        /* Layout dos columnas */
        .layout {
            display: grid;
            grid-template-columns: 340px 1fr;
            gap: 1.5rem;
            align-items: start;
        }

        /* Cards */
        .card-mc {
            background: #fff;
            border-top: 3px solid #ff3b00;
            padding: 1.8rem;
        }

        .card-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1rem;
            letter-spacing: .1em;
            color: #111;
            margin-bottom: 1.4rem;
        }

        /* Campos */
        .field { margin-bottom: 1.4rem; }

        .field label {
            display: block;
            font-size: .6rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #999;
            margin-bottom: .5rem;
        }

        .field input,
        .field select {
            width: 100%;
            border: none;
            border-bottom: 1.5px solid #ddd;
            padding: .6rem 0;
            font-family: 'DM Sans', sans-serif;
            font-size: .92rem;
            color: #111;
            background: transparent;
            outline: none;
            transition: border-color .2s;
            appearance: none;
            -webkit-appearance: none;
        }

        .field input:focus,
        .field select:focus { border-color: #111; }

        .select-wrap { position: relative; }

        .select-wrap::after {
            content: '▾';
            position: absolute;
            right: 0;
            bottom: .6rem;
            font-size: .8rem;
            color: #aaa;
            pointer-events: none;
        }

        /* Alerta mensaje */
        .alerta {
            font-size: .78rem;
            padding: .65rem 1rem;
            margin-bottom: 1rem;
            border-left: 3px solid #ff3b00;
            background: rgba(255,59,0,.06);
            color: #ff3b00;
        }

        .alerta.alert-success {
            border-color: #2d7a2d;
            background: rgba(45,122,45,.06);
            color: #2d7a2d;
        }

        /* Total */
        .total-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .total-label {
            font-size: .65rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: #aaa;
        }

        .total-valor {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.6rem;
            letter-spacing: .05em;
            color: #111;
        }

        /* Botones acción */
        .btn-mc {
            font-family: 'Bebas Neue', sans-serif;
            font-size: .78rem;
            letter-spacing: .2em;
            padding: .6rem 1.2rem;
            border: none;
            cursor: pointer;
            text-decoration: none !important;
            display: inline-block;
            transition: background .2s, color .2s;
        }

        .btn-mc-dark { background: #111; color: #f2f0eb !important; }
        .btn-mc-dark:hover { background: #ff3b00; color: #fff !important; }

        .btn-mc-outline {
            background: transparent;
            color: #111 !important;
            border: 1px solid #ccc;
        }
        .btn-mc-outline:hover { border-color: #111; }

        .btn-mc-red { background: #ff3b00; color: #fff !important; }
        .btn-mc-red:hover { background: #cc2f00; }

        .form-actions {
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
            margin-top: 1.4rem;
        }

        /* Tabla carrito */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr { border-bottom: 1px solid #eee; }

        thead th {
            font-size: .58rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #aaa;
            padding: .8rem 1rem;
            font-weight: 400;
            text-align: left;
        }

        tbody tr {
            border-bottom: 1px solid #f4f4f4;
            transition: background .15s;
        }

        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #fafafa; }

        tbody td {
            padding: .8rem 1rem;
            font-size: .85rem;
            color: #333;
        }

        .btn-quitar {
            font-family: 'Bebas Neue', sans-serif;
            font-size: .65rem;
            letter-spacing: .15em;
            padding: .25rem .65rem;
            background: transparent;
            border: 1px solid #ff3b00;
            color: #ff3b00;
            cursor: pointer;
            transition: background .2s, color .2s;
        }

        .btn-quitar:hover { background: #ff3b00; color: #fff; }

        .empty {
            text-align: center;
            padding: 2rem;
            font-size: .78rem;
            color: #bbb;
            letter-spacing: .1em;
            text-transform: uppercase;
        }

        /* Catálogo btn */
        .btn-catalogo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: .75rem;
            letter-spacing: .2em;
            padding: .5rem 1.1rem;
            background: transparent;
            border: 1px solid #111;
            color: #111;
            cursor: pointer;
            transition: background .2s, color .2s;
            margin-bottom: 1rem;
            display: inline-block;
        }

        .btn-catalogo:hover { background: #111; color: #f2f0eb; }

        /* ── MODAL ── */
        .modal-content { border-radius: 0; border: none; }

        .modal-header {
            background: #111;
            border-bottom: 3px solid #ff3b00;
            padding: 1rem 1.5rem;
        }

        .modal-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.1rem;
            letter-spacing: .1em;
            color: #f2f0eb;
            margin: 0;
        }

        .modal-header .close {
            color: #f2f0eb;
            opacity: .7;
            font-size: 1.4rem;
        }

        .modal-header .close:hover { opacity: 1; }

        .modal-body { padding: 1.5rem; }

        #buscadorModal {
            border: none;
            border-bottom: 1.5px solid #ddd;
            border-radius: 0;
            background: transparent;
            font-family: 'DM Sans', sans-serif;
            font-size: .88rem;
            padding: .6rem 0;
            outline: none;
            margin-bottom: 1.2rem !important;
            box-shadow: none !important;
        }

        #buscadorModal:focus { border-color: #111; box-shadow: none !important; }

        #tablaModal thead th {
            font-size: .58rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #aaa;
            background: #fff;
            font-weight: 400;
            border-bottom: 1px solid #eee !important;
            border: none;
        }

        #tablaModal { border: none !important; }
        #tablaModal td { border: none !important; border-bottom: 1px solid #f4f4f4 !important; font-size: .85rem; }
        #tablaModal tbody tr:hover { background: #fafafa; }

        .btn-usar {
            font-family: 'Bebas Neue', sans-serif;
            font-size: .62rem;
            letter-spacing: .15em;
            padding: .28rem .7rem;
            background: #111;
            border: none;
            color: #f2f0eb;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-usar:hover { background: #ff3b00; }

        .modal-footer {
            border-top: 1px solid #eee;
            padding: 1rem 1.5rem;
        }

        .btn-cerrar {
            font-family: 'Bebas Neue', sans-serif;
            font-size: .75rem;
            letter-spacing: .2em;
            padding: .5rem 1.2rem;
            background: transparent;
            border: 1px solid #ccc;
            color: #111;
            cursor: pointer;
            transition: border-color .2s;
        }

        .btn-cerrar:hover { border-color: #111; }
    </style>
</head>
<body>

<nav th:replace="~{componentes/navbar :: navbar}"></nav>

<div class="page-wrapper">

    <div class="page-header">
        <h1>Nueva Venta</h1>
        <p>Registra los productos y finaliza la venta</p>
    </div>

    <div class="layout">

        <!-- ── Columna izquierda: formulario venta ── -->
        <div class="card-mc">
            <p class="card-title">Datos de la Venta</p>

            <form th:action="@{/venta/terminar}" method="post" th:object="${venta}">

                <div class="field">
                    <label>Asesor de Venta</label>
                    <div class="select-wrap">
                        <select th:field="*{asesorVenta}">
                            <option th:each="a : ${asesorVentaList}"
                                    th:value="${a.id}"
                                    th:text="${a.nombres}"/>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label>Cliente</label>
                    <div class="select-wrap">
                        <select th:field="*{cliente}">
                            <option th:each="c : ${clienteList}"
                                    th:value="${c.id}"
                                    th:text="${c.razonSocial}"/>
                        </select>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-mc btn-mc-dark">Terminar Venta</button>
                    <a th:href="@{/venta/limpiar}" class="btn-mc btn-mc-red">Cancelar</a>
                    <a th:href="@{/venta}" class="btn-mc btn-mc-outline">Ver Listado</a>
                </div>

            </form>
        </div>

        <!-- ── Columna derecha: carrito ── -->
        <div class="card-mc">
            <p class="card-title">Carrito</p>

            <!-- Alerta -->
            <div th:if="${mensaje != null}"
                 th:text="${mensaje}"
                 th:class="${clase == 'success'} ? 'alerta alert-success' : 'alerta'">
            </div>

            <!-- Total -->
            <div class="total-bar">
                <span class="total-label">Total</span>
                <span class="total-valor" th:text="'S/ ' + ${total}"></span>
            </div>

            <!-- Agregar producto -->
            <form th:object="${producto}" th:action="@{/venta/agregar}" method="post">
                <div class="field">
                    <label>Código de producto</label>
                    <input autofocus autocomplete="off"
                           id="campoCodigo"
                           th:field="*{codigo}"
                           type="text"/>
                </div>
            </form>

            <!-- Botón catálogo -->
            <button type="button" class="btn-catalogo"
                    data-toggle="modal" data-target="#modalProductos">
                Ver Catálogo de Productos
            </button>

            <!-- Tabla carrito -->
            <table>
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th>Código</th>
                        <th>Precio</th>
                        <th>Cant.</th>
                        <th>Importe</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr th:if="${session.carrito == null or session.carrito.isEmpty()}">
                        <td colspan="6" class="empty">El carrito está vacío</td>
                    </tr>
                    <tr th:each="producto, iterador : ${session.carrito}">
                        <td th:text="${producto.descripcion}"></td>
                        <td th:text="${producto.codigo}"></td>
                        <td th:text="'S/ ' + ${producto.precioVenta}"></td>
                        <td th:text="${producto.cantidad}"></td>
                        <td th:text="'S/ ' + ${producto.total}"></td>
                        <td>
                            <form th:action="@{/venta/quitar/} + ${iterador.index}" method="post">
                                <button type="submit" class="btn-quitar">Quitar</button>
                            </form>
                        </td>
                    </tr>
                </tbody>
            </table>

        </div>
    </div>
</div>

<!-- ── MODAL CATÁLOGO ── -->
<div class="modal fade" id="modalProductos" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Catálogo de Productos</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                <input type="text" id="buscadorModal"
                       class="form-control mb-3"
                       placeholder="Buscar producto..."/>

                <table class="table" id="tablaModal">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="p : ${productoList}">
                            <td th:text="${p.codigo}"></td>
                            <td th:text="${p.descripcion}"></td>
                            <td th:text="${p.categoria.descripcion}"></td>
                            <td th:text="'S/ ' + ${p.precioVenta}"></td>
                            <td th:text="${p.stock}"></td>
                            <td>
								<div style="display:flex; gap:.4rem; align-items:center;">
								        <input type="number" min="1"
								               th:attr="max=${p.stock}, id='cant_' + ${p.codigo}"
								               value="1"
								               style="width:55px; border:none; border-bottom:1.5px solid #ddd; text-align:center;
								                      font-family:'DM Sans',sans-serif; font-size:.85rem; background:transparent; outline:none;"/>
								        <button type="button" class="btn-usar"
								                th:attr="onclick='usarCodigo(' + '&quot;' + ${p.codigo} + '&quot;' + ')'">
								            Usar
								        </button>
								    </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cerrar" data-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
<script>
    function usarCodigo(codigo) {
        const asesor = document.querySelector('select[name="asesorVenta"]').value;
        const cliente = document.querySelector('select[name="cliente"]').value;
        sessionStorage.setItem('asesorVenta', asesor);
        sessionStorage.setItem('cliente', cliente);
        document.getElementById('campoCodigo').value = codigo;
        $('#modalProductos').modal('hide');
        document.getElementById('campoCodigo').form.submit();
    }

    window.addEventListener('DOMContentLoaded', () => {
        const asesor = sessionStorage.getItem('asesorVenta');
        const cliente = sessionStorage.getItem('cliente');
        if (asesor) document.querySelector('select[name="asesorVenta"]').value = asesor;
        if (cliente) document.querySelector('select[name="cliente"]').value = cliente;
    });

    document.getElementById('buscadorModal').addEventListener('keyup', function() {
        const filtro = this.value.toLowerCase();
        document.querySelectorAll('#tablaModal tbody tr').forEach(fila => {
            fila.style.display = fila.textContent.toLowerCase().includes(filtro) ? '' : 'none';
        });
    });
</script>
</body>
</html>