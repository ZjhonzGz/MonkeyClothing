<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Monkey Clothing - Nueva Venta</title>
    <link rel="stylesheet"
          href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
</head>
<body>
<nav class="navbar navbar-expand-md bg-dark navbar-dark">
    <a class="navbar-brand" href="#">Monkey Clothing</a>
    <div class="collapse navbar-collapse">
        <ul class="navbar-nav">
            <li class="nav-item"><a class="nav-link" th:href="@{/usuario}">Usuarios</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/cliente}">Clientes</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/productos}">Productos</a></li>
            <li class="nav-item"><a class="nav-link" th:href="@{/venta}">Ventas</a></li>
        </ul>
    </div>
</nav>

<div class="container mt-3">
    <div class="row">
        <div class="col-lg-6">
            <form th:action="@{/venta/terminar}" method="post" th:object="${venta}">

                <div class="form-group">
                    <label>Asesor de Venta</label>
                    <select th:field="*{asesorVenta}" class="form-control">
                        <option th:each="a : ${asesorVentaList}"
                                th:value="${a.id}"
                                th:text="${a.nombres}"/>
                    </select>
                </div>

                <div class="form-group">
                    <label>Cliente</label>
                    <select th:field="*{cliente}" class="form-control">
                        <option th:each="c : ${clienteList}"
                                th:value="${c.id}"
                                th:text="${c.razonSocial}"/>
                    </select>
                </div>

                <button type="submit" class="btn btn-success">Terminar Venta</button>
                <a th:href="@{/venta/limpiar}" class="btn btn-danger">Cancelar Venta</a>
                <a th:href="@{/venta}" class="btn btn-primary">Listado Ventas</a>
            </form>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-lg-12">

            <div th:if="${mensaje != null}"
                 th:text="${mensaje}"
                 th:classappend="'alert-' + ${clase}"
                 class="alert">
            </div>

            <!-- botón para abrir modal -->
            <button type="button" class="btn btn-secondary btn-sm mb-2"
                    data-toggle="modal" data-target="#modalProductos">
                📋 Ver Catálogo de Productos
            </button>

            <form th:object="${producto}" th:action="@{/venta/agregar}" method="post">
                <div class="form-group">
                    <label>Código de producto</label>
                    <input autofocus autocomplete="off"
                           id="campoCodigo"
                           th:field="*{codigo}"
                           placeholder="Ingresa el código y presiona Enter"
                           type="text" class="form-control"/>
                </div>
            </form>

            <h4 th:text="${'Total: S/. ' + total}"></h4>

            <table class="table table-bordered mt-2">
                <thead class="table-dark">
                    <tr>
                        <th>Descripción</th>
                        <th>Código</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Importe</th>
                        <th>Quitar</th>
                    </tr>
                </thead>
                <tbody>
                    <tr th:each="producto, iterador : ${session.carrito}">
                        <td th:text="${producto.descripcion}"></td>
                        <td th:text="${producto.codigo}"></td>
                        <td th:text="${producto.precioVenta}"></td>
                        <td th:text="${producto.cantidad}"></td>
                        <td th:text="${producto.total}"></td>
                        <td>
                            <form th:action="@{/venta/quitar/} + ${iterador.index}" method="post">
                                <button type="submit" class="btn btn-danger btn-sm">Quitar</button>
                            </form>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODAL CATÁLOGO DE PRODUCTOS -->
<div class="modal fade" id="modalProductos" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">👕 Catálogo de Productos</h5>
                <button type="button" class="close text-white"
                        data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">

                <!-- buscador dentro del modal -->
                <input type="text" id="buscadorModal"
                       class="form-control mb-3"
                       placeholder="Buscar producto..."/>

                <table class="table table-striped table-bordered" id="tablaModal">
                    <thead class="table-dark">
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="p : ${productoList}">
                            <td th:text="${p.codigo}"></td>
                            <td th:text="${p.descripcion}"></td>
                            <td th:text="${p.categoria.descripcion}"></td>
                            <td th:text="${p.precioVenta}"></td>
                            <td th:text="${p.stock}"></td>
                            <td>
                                <button type="button" class="btn btn-success btn-sm"
                                        th:attr="onclick='usarCodigo(' + '&quot;' + ${p.codigo} + '&quot;' + ')'">
                                    Usar código
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>

<script>
    // pega el código en el input y cierra el modal
    function usarCodigo(codigo) {
        document.getElementById('campoCodigo').value = codigo;
        $('#modalProductos').modal('hide');
        document.getElementById('campoCodigo').form.submit();
    }

    // buscador en tiempo real dentro del modal
    document.getElementById('buscadorModal').addEventListener('keyup', function() {
        const filtro = this.value.toLowerCase();
        const filas = document.querySelectorAll('#tablaModal tbody tr');
        filas.forEach(fila => {
            const texto = fila.textContent.toLowerCase();
            fila.style.display = texto.includes(filtro) ? '' : 'none';
        });
    });
</script>
</body>
</html>