<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Monkey Clothing — Editar Usuario</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #f2f0eb;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #111;
        }

        .page-wrapper {
            max-width: 560px;
            margin: 2.5rem auto;
            padding: 0 1.5rem;
        }

        .page-header { margin-bottom: 1.8rem; }

        .page-header h1 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            letter-spacing: .08em;
            color: #111;
            line-height: 1;
        }

        .page-header p {
            font-size: .72rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: #aaa;
            margin-top: .3rem;
        }

        .form-card {
            background: #fff;
            border-top: 3px solid #ff3b00;
            padding: 2.2rem 2rem;
        }

        .field { margin-bottom: 1.6rem; }

        .field label {
            display: block;
            font-size: .62rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #999;
            margin-bottom: .5rem;
        }

        .field input {
            width: 100%;
            border: none;
            border-bottom: 1.5px solid #ddd;
            padding: .6rem 0;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            color: #111;
            background: transparent;
            outline: none;
            transition: border-color .2s;
        }

        .field input:focus { border-color: #111; }

        .field-error {
            display: block;
            font-size: .7rem;
            color: #ff3b00;
            margin-top: .4rem;
            letter-spacing: .03em;
        }

        .pw-wrap { position: relative; }
        .pw-wrap input { padding-right: 2rem; }

        .pw-eye {
            position: absolute;
            right: 0;
            bottom: .5rem;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            color: #bbb;
            transition: color .2s;
            line-height: 1;
        }

        .pw-eye:hover { color: #111; }

        .rol-fijo {
            display: inline-block;
            font-size: .58rem;
            letter-spacing: .15em;
            text-transform: uppercase;
            background: #111;
            color: #f2f0eb;
            padding: .3rem .9rem;
            margin-top: .3rem;
        }

        .form-actions {
            display: flex;
            gap: .8rem;
            margin-top: 2rem;
        }

        .btn-guardar {
            background: #111;
            color: #f2f0eb !important;
            border: none;
            padding: .75rem 1.6rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: .85rem;
            letter-spacing: .2em;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-guardar:hover { background: #ff3b00; }

        .btn-cancelar {
            background: transparent;
            color: #111 !important;
            border: 1px solid #ccc;
            padding: .75rem 1.6rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: .85rem;
            letter-spacing: .2em;
            cursor: pointer;
            transition: border-color .2s;
            text-decoration: none !important;
            display: inline-block;
        }

        .btn-cancelar:hover { border-color: #111; }
    </style>
</head>
<body>

<nav th:replace="~{componentes/navbar :: navbar}"></nav>

<div class="page-wrapper">

    <div class="page-header">
        <h1>Editar Usuario</h1>
        <p>Modifica los datos del usuario</p>
    </div>

    <div class="form-card">
        <form th:action="@{/usuario/update/{id}(id=${usuario.id})}"
              th:object="${usuario}" method="post">

            <input type="hidden" th:field="*{id}"/>
            <input type="hidden" name="idrol" value="1"/>

            <div class="field">
                <label>Nombres</label>
                <input type="text" th:field="*{nombres}"/>
                <span class="field-error"
                      th:if="${#fields.hasErrors('nombres')}"
                      th:errors="*{nombres}"></span>
            </div>

            <div class="field">
                <label>Apellidos</label>
                <input type="text" th:field="*{apellidos}"/>
                <span class="field-error"
                      th:if="${#fields.hasErrors('apellidos')}"
                      th:errors="*{apellidos}"></span>
            </div>

            <div class="field">
                <label>Usuario</label>
                <input type="text" th:field="*{usuario}"/>
                <span class="field-error"
                      th:if="${#fields.hasErrors('usuario')}"
                      th:errors="*{usuario}"></span>
            </div>

            <div class="field">
                <label>Contraseña</label>
                <div class="pw-wrap">
                    <input type="password" th:field="*{clave}" id="clave"/>
                    <button type="button" class="pw-eye" onclick="togglePw()" title="Mostrar contraseña">
                        <svg id="icon-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg id="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                             style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                            <line x1="1" y1="1" x2="23" y2="23"/>
                        </svg>
                    </button>
                </div>
                <span class="field-error"
                      th:if="${#fields.hasErrors('clave')}"
                      th:errors="*{clave}"></span>
            </div>

            <div class="field">
                <label>Rol</label>
                <span class="rol-fijo">Administrador</span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-guardar">Actualizar</button>
                <a href="/usuario" class="btn-cancelar">Cancelar</a>
            </div>

        </form>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
<script>
    function togglePw() {
        const input  = document.getElementById('clave');
        const eyeOn  = document.getElementById('icon-eye');
        const eyeOff = document.getElementById('icon-eye-off');
        const visible = input.type === 'text';
        input.type       = visible ? 'password' : 'text';
        eyeOn.style.display  = visible ? '' : 'none';
        eyeOff.style.display = visible ? 'none' : '';
    }
</script>
</body>
</html>