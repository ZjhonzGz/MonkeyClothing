// Construye la URL del embed de Google Maps para una sola tienda
function buildEmbedSingle(lat, lng) {
  return `https://maps.google.com/maps?q=${lat},${lng}&z=16&output=embed`;
}

// Construye la URL del embed mostrando las 3 tiendas centradas en Lima
function buildEmbedAll(userLat, userLng) {
  // Centramos el mapa en Lima; los pines de tiendas se ponen como marcadores
  const markers = STORES.map(s => `${s.lat},${s.lng}`).join('|');
  // Cuando hay ubicación del usuario, centramos entre él y las tiendas
  const center = userLat
    ? `${userLat},${userLng}`
    : '-12.0900,-77.0350';   // centro aproximado de Lima
  return `https://maps.google.com/maps?q=${STORES[0].lat},${STORES[0].lng}&z=13&output=embed`;
}

// Abre el modal de una tienda individual
function openMapSingle(lat, lng, name, addr) {
  const modal   = document.getElementById('modalSingle');
  const backdrop = document.getElementById('mapBackdrop');
  const iframe  = document.getElementById('iframeSingle');
  const title   = document.getElementById('modalSingleTitle');
  const address = document.getElementById('modalSingleAddr');
  const dirLink = document.getElementById('linkSingleDir');

  title.textContent   = name;
  address.textContent = addr;
  iframe.src          = buildEmbedSingle(lat, lng);
  dirLink.href        = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;

  modal.classList.add('active');
  backdrop.classList.add('active');
  document.body.style.overflow = 'hidden';
}

// Abre el modal de todas las tiendas + geolocalización
function openMapAll() {
  const modal    = document.getElementById('modalAll');
  const backdrop = document.getElementById('mapBackdrop');
  const iframe   = document.getElementById('iframeAll');
  const statusEl = document.getElementById('locStatusText');
  const locRow   = document.getElementById('locationStatus');

  // Carga el mapa centrado en las tiendas de Lima
  iframe.src = buildEmbedAll(null, null);

  modal.classList.add('active');
  backdrop.classList.add('active');
  document.body.style.overflow = 'hidden';

  // Intentar geolocalización
  if (!navigator.geolocation) {
    statusEl.textContent = 'Geolocalización no disponible';
    locRow.classList.add('error');
    return;
  }

  statusEl.textContent = 'Detectando tu ubicación...';
  locRow.classList.remove('found', 'error');

  navigator.geolocation.getCurrentPosition(
    pos => {
      const { latitude: lat, longitude: lng } = pos.coords;

      // Recarga el mapa centrado en el usuario con las tiendas visibles
      iframe.src = `https://maps.google.com/maps?q=${lat},${lng}&z=13&output=embed`;

      // Calcula la tienda más cercana
      const nearest = STORES.reduce((prev, curr) => {
        const dPrev = dist(lat, lng, prev.lat, prev.lng);
        const dCurr = dist(lat, lng, curr.lat, curr.lng);
        return dCurr < dPrev ? curr : prev;
      });

      const km = dist(lat, lng, nearest.lat, nearest.lng).toFixed(1);
      statusEl.textContent = `Tu tienda más cercana: ${nearest.name} (${km} km)`;
      locRow.classList.add('found');

      // Resalta la tarjeta de la tienda más cercana
      document.querySelectorAll('.map-store-card').forEach((card, i) => {
        card.classList.toggle('active', i === nearest.id - 1);
      });
    },
    () => {
      statusEl.textContent = 'No se pudo obtener tu ubicación';
      locRow.classList.add('error');
    },
    { timeout: 8000 }
  );
}

// Actualiza el iframe para "volar" a una tienda al hacer clic en la sidebar
function flyTo(lat, lng) {
  const iframe = document.getElementById('iframeAll');
  if (iframe) {
    iframe.src = buildEmbedSingle(lat, lng);
  }
  // Resalta la tarjeta clickeada
  document.querySelectorAll('.map-store-card').forEach(card => {
    const onclick = card.getAttribute('onclick') || '';
    card.classList.toggle('active', onclick.includes(`${lat}`));
  });
}

// Cierra un modal por ID
function closeModal(id) {
  document.getElementById(id).classList.remove('active');
  // Solo oculta el backdrop si no hay otro modal abierto
  const anyOpen = document.querySelector('.map-modal.active');
  if (!anyOpen) {
    document.getElementById('mapBackdrop').classList.remove('active');
    document.body.style.overflow = '';
    // Limpia el iframe al cerrar para detener cualquier carga
    const iframe = document.querySelector(`#${id} iframe`);
    if (iframe) setTimeout(() => { iframe.src = ''; }, 350);
  }
}

// Cierra todos los modales (clic en el backdrop)
function closeAllModals() {
  document.querySelectorAll('.map-modal.active').forEach(m => {
    m.classList.remove('active');
    const iframe = m.querySelector('iframe');
    if (iframe) setTimeout(() => { iframe.src = ''; }, 350);
  });
  document.getElementById('mapBackdrop').classList.remove('active');
  document.body.style.overflow = '';
}

// Cerrar con tecla Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeAllModals();
});

// Distancia Haversine simplificada (devuelve km)
function dist(lat1, lng1, lat2, lng2) {
  const R    = 6371;
  const dLat = ((lat2 - lat1) * Math.PI) / 180;
  const dLng = ((lng2 - lng1) * Math.PI) / 180;
  const a    =
    Math.sin(dLat / 2) ** 2 +
    Math.cos((lat1 * Math.PI) / 180) *
    Math.cos((lat2 * Math.PI) / 180) *
    Math.sin(dLng / 2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}