# Nombre de la aplicaciˇn
spring.application.name=monkeyclothing

# Cambiamos el puerto para que no choque con tu proyecto de clase
server.port=8081

# ===============================
# CONEXION A MYSQL
# ===============================
spring.datasource.url=jdbc:mysql://localhost:3306/dbmonkeyclothes?useSSL=false&serverTimezone=UTC
spring.datasource.username=root
spring.datasource.password=mysql
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ===============================
# JPA / HIBERNATE
# ===============================

# Dialecto moderno (evita warning deprecado)
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect

# NO tocar la BD porque ya existe (usamos tu script)
spring.jpa.hibernate.ddl-auto=none

# Mostrar SQL en consola (˙til para aprender)
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# ===============================
# THYMELEAF (para desarrollo)
# ===============================
spring.thymeleaf.cache=false