package com.cibertec.monkey.entity;

import jakarta.persistence.*;
import lombok.*;

@Entity
@Table(name = "categorias")
@Data
@NoArgsConstructor
@AllArgsConstructor
public class Categoria {

    @Id
    @Column(length = 10)
    private String idcate;

    @Column(nullable = false, unique = true, length = 50)
    private String descripcion;
}