    </div>
    <div class="collection-grid reveal">
      <article class="col-card col-card--hero">
        <div class="col-card__img">
          <img src="images/col-core.jpg" alt="Core Collection" class="col-card__art" />
          <div class="col-card__deco"></div>
        </div>
        <div class="col-card__info">
          <span class="col-card__tag">Signature Series</span>
          <h3 class="col-card__name">Core Collection</h3>
          <p class="col-card__desc">Los clásicos que definen quiénes somos</p>
        </div>
      </article>
      <div class="col-right">
        <article class="col-card">
          <div class="col-card__img">
            <img src="images/col-temporada.jpg" alt="Temporada" class="col-card__art" />
            <div class="col-card__deco"></div>
          </div>
          <div class="col-card__info">
            <span class="col-card__tag">Spring / Summer</span>
            <h3 class="col-card__name">Temporada</h3>
          </div>
        </article>
        <article class="col-card">
