  <!-- ======= NOSOTROS / MANIFESTO ======= -->
  <section class="section manifesto" id="nosotros">
    <div class="manifesto__bg-text" aria-hidden="true">MONKEY</div>
    <div class="manifesto__content reveal">
      <span class="section-tag">// 02 — Manifiesto</span>
      <h2 class="manifesto__title">Más Que<br>Ropa. Una<br>Actitud.</h2>
      <div class="manifesto__body">
        <p>Monkey Clothing nació en las calles y vive en ellas. No seguimos tendencias, las creamos. Nuestra ropa es para quienes se atreven a ser diferentes, para quienes ven la ciudad como su pasarela y cada día como una oportunidad de expresarse sin filtros.</p>
        <div class="manifesto__stats">
          <div class="stat">
            <span class="stat__num">6+</span>
            <span class="stat__label">Años en la calle</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======= DROPS ======= -->
