          onclick="openMapSingle(-12.0464, -77.0428, 'Lima Centro', 'Jr. de la Unión 456, Lima')">
          Ver mapa
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 8h10M9 4l4 4-4 4"/>
          </svg>
        </button>
      </div>
      <div class="store-item">
        <div class="store-item__num">02</div>
