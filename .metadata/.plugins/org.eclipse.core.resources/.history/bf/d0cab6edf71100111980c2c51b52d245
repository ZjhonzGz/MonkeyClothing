  <!-- ══════════════════════════════════════════════════════
       NEWSLETTER — BANNER FLOTANTE
       Aparece 5 s después de cargar, esquina inferior izquierda
       Si el usuario ya se suscribió en esta sesión no aparece
       ══════════════════════════════════════════════════════ -->
  <div class="nl-banner" id="nlBanner" role="complementary">
    <button class="nl-banner__close" onclick="nlCerrarBanner()" aria-label="Cerrar">✕</button>
    <div class="nl-banner__body">
      <div class="nl-banner__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
        </svg>
      </div>
      <div class="nl-banner__text">
        <strong>¡Únete a la familia Monkey!</strong>
        <span>Drops exclusivos y novedades antes que nadie.</span>
      </div>
    </div>
    <button class="nl-banner__btn" onclick="nlAbrirModal()">
      Suscribirme
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 8h10M9 4l4 4-4 4"/>
      </svg>
    </button>
  </div>

  <!-- ══════════════════════════════════════════════════════
       NEWSLETTER — MODAL DE SUSCRIPCIÓN
       ══════════════════════════════════════════════════════ -->
  <div class="nl-overlay" id="nlOverlay" onclick="nlCerrarModal()"></div>

  <div class="nl-modal" id="nlModal" role="dialog" aria-modal="true" aria-label="Suscribirse al newsletter">
    <button class="nl-modal__close" onclick="nlCerrarModal()" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <!-- Estado: formulario -->
    <div id="nlFormState">
      <span class="nl-modal__tag">// Newsletter</span>
      <h2 class="nl-modal__title">Sé parte de<br>la <em>familia</em>.</h2>
      <p class="nl-modal__sub">Drops antes que nadie, ofertas exclusivas y contenido para la comunidad.</p>

      <div class="nl-field">
        <label class="nl-label" for="nlNombre">Nombre *</label>
        <input type="text" id="nlNombre" class="nl-input" placeholder="Tu nombre completo" maxlength="100" autocomplete="name"/>
        <span class="nl-error" id="nlErrNombre"></span>
      </div>

      <div class="nl-field">
        <label class="nl-label" for="nlTelefono">Teléfono / WhatsApp</label>
        <input type="tel" id="nlTelefono" class="nl-input" placeholder="9XXXXXXXX" maxlength="20" autocomplete="tel"/>
      </div>

      <div class="nl-field">
        <label class="nl-label" for="nlEmail">Email *</label>
        <input type="email" id="nlEmail" class="nl-input" placeholder="tu@correo.com" maxlength="150" autocomplete="email"/>
        <span class="nl-error" id="nlErrEmail"></span>
      </div>

      <button class="nl-submit" id="nlSubmitBtn" onclick="nlEnviar()">
        <span id="nlSubmitTxt">Suscribirme</span>
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 10h12M12 5l5 5-5 5"/>
        </svg>
      </button>
      <p class="nl-privacy">Sin spam. Puedes darte de baja cuando quieras.</p>
    </div>

    <!-- Estado: éxito -->
