            <img src="images/col-accesorios.jpg" alt="Accesorios" class="col-card__art" />
            <div class="col-card__deco"></div>
          </div>
          <div class="col-card__info">
            <span class="col-card__tag">Headwear</span>
            <h3 class="col-card__name">Accesorios</h3>
          </div>
        </article>
        <article class="col-card">
          <div class="col-card__img">
            <img src="images/col-exclusivos.jpg" alt="Exclusivos" class="col-card__art" />
            <div class="col-card__deco"></div>
          </div>
          <div class="col-card__info">
            <span class="col-card__tag">Limited Drop</span>
            <h3 class="col-card__name">Exclusivos</h3>
          </div>
        </article>
        <article class="col-card">
          <div class="col-card__img">
            <img src="images/col-outerlayer.jpg" alt="Outer Layer" class="col-card__art" />
            <div class="col-card__deco"></div>
          </div>
          <div class="col-card__info">
            <span class="col-card__tag">Outerwear</span>
            <h3 class="col-card__name">Outer Layer</h3>
          </div>
